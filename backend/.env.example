PORT=3001
NODE_ENV=development

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-second-long-random-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

BREVO_API_KEY=
BREVO_FROM=receiptmind <no-reply@example.com>

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_APP_NAME=ReceiptMind
OPENROUTER_APP_URL=http://localhost:3000

# Backward-compatible aliases
OPENAI_API_KEY=
OPENAI_MODEL=google/gemini-2.0-flash-001

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash-001

AI_REQUEST_TIMEOUT_MS=45000
AI_MAX_RETRIES=1

STORAGE_PATH=./uploads
BASE_URL=http://localhost:3001
MAX_FILE_SIZE=10485760

FRONTEND_URL=http://localhost:3000
