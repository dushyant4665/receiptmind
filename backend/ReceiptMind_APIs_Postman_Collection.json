    {
      "name": "Receipts",
      "item": [
        {
          "name": "Upload Receipts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "receipts",
                  "type": "file",
                  "src": "/path/to/receipt.jpg"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/receipts/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "receipts", "upload"]
            },
            "description": "Upload receipt files (images/PDFs). Supports multiple files. AI extracts vendor, amount, date, category."
          },
          "response": []
        },
        {
          "name": "List Receipts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
